[0.000, "o", "  \u001b[2mProject\u001b[0m  distillery\r\n  \u001b[2mAuthor\u001b[0m   norrie\r\n  \u001b[2mType\u001b[0m     \u001b[33mdecision\u001b[0m\r\n\r\n"]
[0.000, "o", "  \u001b[1mSummary\u001b[0m\r\n  Use DuckDB with HNSW indexes for vector similarity search.\r\n"]
[0.000, "o", "  Single-file storage avoids network hops; VSS extension handles\r\n  cosine similarity natively.\r\n\r\n"]
[0.000, "o", "  \u001b[2mTags\u001b[0m  \u001b[34m#duckdb\u001b[0m  \u001b[34m#vector-search\u001b[0m  \u001b[34m#architecture\u001b[0m\r\n\r\n  \u001b[2mDedup\u001b[0m  no similar entries found\r\n\r\n"]
