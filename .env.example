# Distillery Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# =============================================================================
# Embedding Provider
# =============================================================================

# Jina AI API key — used for embedding entries (default provider)
# Get your key at: https://jina.ai/
JINA_API_KEY=your-jina-api-key-here

# OpenAI API key — alternative embedding provider
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# GitHub OAuth (HTTP transport / team access)
# =============================================================================

# GitHub OAuth App Client ID — required for HTTP transport with GitHub OAuth
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-oauth-client-id

# GitHub OAuth App Client Secret — required for HTTP transport with GitHub OAuth
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# Base URL for OAuth redirect (e.g. https://distillery-mcp.fly.dev)
# DISTILLERY_BASE_URL=https://your-deployment-url.example.com

# Optional: GitHub token for org membership checks (fine-grained PAT with read:org scope)
# GITHUB_ORG_CHECK_TOKEN=github_pat_your_token_here

# Allowed GitHub orgs (comma-separated) — restricts access to org members
# DISTILLERY_ALLOWED_ORGS=your-org,another-org

# =============================================================================
# Storage
# =============================================================================

# MotherDuck token — required for MotherDuck cloud storage backend
# Get your token at: https://motherduck.com/
# MOTHERDUCK_TOKEN=your-motherduck-token-here

# AWS credentials — required for S3 storage backend
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_SESSION_TOKEN=your-aws-session-token  # optional, for temporary credentials
# AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# Server Configuration
# =============================================================================

# Path to Distillery YAML config file (default: distillery-dev.yaml in cwd)
DISTILLERY_CONFIG=distillery-dev.yaml

# Host and port for HTTP transport (defaults: 0.0.0.0 and 8000)
# DISTILLERY_HOST=0.0.0.0
# DISTILLERY_PORT=8000

# Git commit SHA injected at build time for version reporting
# DISTILLERY_BUILD_SHA=dev

# =============================================================================
# Webhooks
# =============================================================================

# Webhook secret for validating incoming webhook payloads (HMAC-SHA256)
# DISTILLERY_WEBHOOK_SECRET=your-webhook-secret-here

# =============================================================================
# Feed Sources
# =============================================================================

# GitHub token for polling GitHub feed sources (public repos work without a token)
# GITHUB_TOKEN=github_pat_your_token_here
